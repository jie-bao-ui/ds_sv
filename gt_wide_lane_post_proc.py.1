            centerline['z'] = []
            centerline['z'].extend(new_centerline['z'])
        print(f"consume time {time.time() - start_time}")

def write_back_modified_centerline(centerlines, json_data, file_path):
    if len(centerlines) == len(json_data['annotation']):
        for i, lane in enumerate(centerlines):
            if 1 not in lane['lanewidth']:
                continue
            if len(lane['x']) == len(json_data['annotation'][i]['lineData']):
                print(f"update {i}th lane in centerline with {len(lane['x'])} points")
                for idx, _ in enumerate(lane['x']):
                    json_data['annotation'][i]['lineData'][idx]['x'] = lane['x'][idx]
                    json_data['annotation'][i]['lineData'][idx]['y'] = lane['y'][idx]
                    json_data['annotation'][i]['lineData'][idx]['z'] = lane['z'][idx]
    with open(file_path, 'w', encoding='utf-8') as f:
        json.dump(json_data, f)

def write_lanes_to_csv(centerlines, file_path):
    data_rows = []
    data_rows.append(["wkt", "id", "widelane"])
    for idx, lane in enumerate(centerlines):
        str_out = 'LINESTRING('
        for idx_p, x_val in enumerate(lane['x']):
            str_out = str_out + f"{lane['x'][idx_p]}" + " " + f"{lane['y'][idx_p]}"
            if idx_p + 1 < len(lane['x']):
                str_out = str_out + ','
        str_out = str_out + ")"
        is_wide = 0
        if 1 in lane['lanewidth']:
            is_wide = 1
        data_rows.append([str_out, str(idx), str(is_wide)])
    with open(file_path, 'w', newline="", encoding='utf-8') as f:
        writer = csv.writer(f)
        writer.writerows(data_rows)
