def draw_lanes(lane_data : list, wide_info : dict):
    plt.figure(figsize=(8, 6))

    plot_data = []
    for i in lane_data:
        data_dict = {}
        data_dict["id"] = i["line_num"]
        points = [[k["x"], k["y"]] for k in i["lineData"]]
        data_dict["points"] = points
        plot_data.append(data_dict)
    # for m in plot_data:
    #     print(f"id: {m['id']}, point size: {len(m['points'])}")
    # 遍历数据并绘图
    for idx, item in enumerate(plot_data):
        # 提取id和points
        obj_id = item["id"]
        points = item["points"]
        
        # 拆分points为x、y坐标列表（[[x1,y1],[x2,y2]] → x=[x1,x2], y=[y1,y2]）
        x = [p[0] for p in points]
        y = [p[1] for p in points]
        
        # 绘制折线 + 散点（双效果更清晰）
        # label：图例名称，color：指定颜色，marker：点的样式，linewidth：线宽
        plt.plot(x, y, label=f'ID {obj_id}', color=get_distinct_random_color(), marker='o', linewidth=0.01)
        # 可选：单独绘制散点（若不需要折线，仅保留这行即可）
        # plt.scatter(x, y, label=f'ID {obj_id}', color=colors[idx], s=50)
        for k, v in wide_info.items():
            if k == obj_id:
                label_idx = 0
                for r in v:
                    if r[0] <= r[1] and r[0] >=0 and r[1] < len(points):
                        label_idx += 1
                        x = [p[0] for p in points[r[0] : r[1]+1]]
                        y = [p[1] for p in points[r[0] : r[1]+1]]
                        plt.plot(x, y, label=f'ID {obj_id}_{label_idx}', color=(0.5,0.5,0.5), marker='*', linewidth=0.04)

    # 添加图表元素
    plt.xlabel('X axis', fontsize=12)  # X轴标签
    plt.ylabel('Y axis', fontsize=12)  # Y轴标签
    plt.title('display points', fontsize=14, fontweight='bold')  # 标题
    plt.legend(fontsize=10)  # 显示图例（对应label）
    plt.grid(True, alpha=0.3)  # 显示网格（alpha调整透明度）
    plt.axis('equal')  # 可选：让x/y轴刻度等比例，避免变形
    # plt.savefig('wide_lane.svg', format='svg', bbox_inches='tight', dpi=300)
    plt.show()

def get_centerline_json_data(file_path : str):
    if not os.path.exists(file_path):
        return None
    try:
        with open(file_path, 'r', encoding='utf-8') as f_read:
            json_data = json.load(f_read)
            if "annotation" not in json_data:
                return None
            if len(json_data["annotation"]) == 0:
                return None
            for ele in json_data["annotation"]:
                if "lineData" not in ele:
                    return None
                if len(ele["lineData"]) == 0:
                    continue
                for ele1 in ele["lineData"]:
                    if "direction" not in ele1:
                        return None
                    if "lanewidth" not in ele1:
                        return None
            return json_data
    except Exception as e:
        raise ValueError(f"failed reading {file_path} as {str(e)}")

