def load_lane_from_gt(json_data, results):
    results['gt_bev_centerline'] = {'centerline':[]}
    for lane in json_data['annotation']:
        x_s = [ele['x'] for ele in lane['lineData']]
        y_s = [ele['y'] for ele in lane['lineData']]
        z_s = [ele['z'] for ele in lane['lineData']]
        lanewidths = [ele['lanewidth'] for ele in lane['lineData']]
        new_lane = {}
        new_lane['x'] = x_s
        new_lane['y'] = y_s
        new_lane['z'] = z_s
        new_lane['lanewidth'] = lanewidths
        results['gt_bev_centerline']['centerline'].append(new_lane)

def cubic_bezier_smooth(p0, p1, p2, p3, steps):
    out_points = {'x': [], 'y': [], 'z': []}
    for i in range(1, steps):
        t = i * 1.0 / steps
        t_sq = t ** 2
        t_cu = t ** 3
        one_minus_t = 1 - t
        one_minus_t_sq  = one_minus_t ** 2
        one_minus_t_cu  = one_minus_t ** 3
        x = one_minus_t_cu * p0[0] + 3 * one_minus_t_sq * t * p1[0] + 3 * one_minus_t * t_sq * p2[0] + t_cu * p3[0]
        y = one_minus_t_cu * p0[1] + 3 * one_minus_t_sq * t * p1[1] + 3 * one_minus_t * t_sq * p2[1] + t_cu * p3[1]
        z = one_minus_t_cu * p0[2] + 3 * one_minus_t_sq * t * p1[2] + 3 * one_minus_t * t_sq * p2[2] + t_cu * p3[2]
        out_points['x'].append(x)
        out_points['y'].append(y)
        out_points['z'].append(z)
    return out_points

def rebuild_wide_lane(results):
    if 'gt_bev_centerline' not in results.keys() or 'gt_bev_lane_freespace' not in results.keys():
        return
    if 'centerline' not in results['gt_bev_centerline'].keys():
        return
    if 'lane' not in results['gt_bev_lane_freespace'].keys():
        return
    for lane_idx, centerline in enumerate(results['gt_bev_centerline']['centerline']):
        if 'lanewidth' not in centerline.keys() or 'x' not in centerline.keys() or 'y' not in centerline.keys() or 'z' not in centerline.keys() or len(centerline['x']) != len(centerline['lanewidth']) or len(centerline['x']) != len(centerline['y']) or len(centerline['x']) != len(centerline['z']):
            continue
        if 1 not in centerline['lanewidth']:
            continue
        #get wide lane ranges
        wide_ranges = []
        in_width = 0
        for idx, width in enumerate(centerline['lanewidth']):
            if width == 1:
                if in_width == 0:
                    wide_ranges.append([idx, idx])
                else:
                    wide_ranges[-1][1] = idx
                in_width = 1
            else:
                in_width = 0
        if not wide_ranges:
            continue
        start_time  = time.time()
        for start, end in wide_ranges:    
            nearest_line_vote = {}
            nearest_table = []
            for idx in range(start, end+1):
                checkpoint = [centerline['x'][idx], centerline['y'][idx], centerline['z'][idx]]
                min_dist = 1e10
                min_idx = -1
                min_vec = []
                min_target_p_idx = -1
                for line_idx, line in enumerate(results['gt_bev_lane_freespace']['lane']):
                    if 'x' not in line.keys() or 'y' not in line.keys() or 'z' not in line.keys() or len(line['x']) != len(line['y']) or len(line['x']) != len(line['z']):
                        continue
                    for idx_p, x in enumerate(line['x']):
                        point_target = [line['x'][idx_p], line['y'][idx_p], line['z'][idx_p]]
                        if abs(point_target[0] - checkpoint[0]) > 3.5 or abs(point_target[1] - checkpoint[1]) > 3.5:
                            continue
                        vec_lane_line = [point_target[0] - checkpoint[0], point_target[1] - checkpoint[1], point_target[2] - checkpoint[2]]
                        dist = (vec_lane_line[0]*vec_lane_line[0] + vec_lane_line[1]*vec_lane_line[1] + vec_lane_line[2]*vec_lane_line[2]) 
                        if idx < end:
                            next_point = [centerline['x'][idx+1], centerline['y'][idx+1], centerline['z'][idx+1]]
                            vec_forward_diff = [next_point[0] - checkpoint[0], next_point[1] - checkpoint[1], next_point[2] - checkpoint[2]]
                            cos_heading = vec_forward_diff[0] * vec_lane_line[0] + vec_forward_diff[1] * vec_lane_line[1]
                            norm_vec_fwd_xy = (vec_forward_diff[0] * vec_forward_diff[0] + vec_forward_diff[1] * vec_forward_diff[1]) ** 0.5
                            norm_vec_linelane_xy = (vec_lane_line[0] * vec_lane_line[0] + vec_lane_line[1] * vec_lane_line[1]) ** 0.5
                            if abs(cos_heading / (norm_vec_fwd_xy * norm_vec_linelane_xy)) > 0.707:
                                continue
                        if dist < min_dist:
                            min_dist = dist
                            min_idx = line_idx
                            min_vec = vec_lane_line
                            min_target_p_idx = idx_p
                if min_idx > -1:
                    nearest_table.append([idx, min_idx, min_dist, min_vec[0], min_vec[1], min_vec[2], min_target_p_idx])
                    if min_idx in nearest_line_vote.keys():
                        nearest_line_vote[min_idx] = nearest_line_vote[min_idx] + 1
                    else:
                        nearest_line_vote[min_idx] = 1
            vote_idx = -1
            max_vote = 0
            for vidx, vt in nearest_line_vote.items():
                if vt > max_vote:
                    vote_idx = vidx
                    max_vote = vt
            if vote_idx > -1 :
                print(f"centerline idx {lane_idx} in range {start} {end} match nearest line {vote_idx}")
                start_target_idx = -1
                start_lane_idx = -1
                start_vec = []
                cur_vec = []
                dist_min = -1
                start_target_p_idx = -1
                for a,b,c,d,e,f,g in nearest_table:
                    if b == vote_idx:
                        start_target_idx = b
                        start_lane_idx = a
                        start_vec = [d, e, f]
                        dist_min = c
                        start_target_p_idx = g
                        break
                print(f"start_target_idx {start_target_idx}  start_lane_idx {start_lane_idx} start_vec {start_vec[0] * 0.25 /dist_min} {start_vec[1] * 0.25 /dist_min} {start_vec[2] * 0.25/dist_min} target start idx {start_target_p_idx}")
                if start_lane_idx == -1 or start_target_idx == -1 or start_target_p_idx == -1:
                    continue
                loop1 = 0
                loop2 = 0
                loop3 = 0
                last_idx = 0
                begin_idx = -1
                for idx_lane in range(start, end+1):
                    if idx_lane == start_lane_idx:
                        break
                    # if centerline['lanewidth'][idx_lane] != 1:
                    #     continue
                    loop1 = loop1 + 1
                    norm = (start_vec[0]*start_vec[0] + start_vec[1]*start_vec[1] + start_vec[2]*start_vec[2]) ** 0.5
                    cur_vec = [start_vec[0] / norm, start_vec[1] / norm, start_vec[2] / norm]
                    centerline['x'][idx_lane] = centerline['x'][idx_lane] + cur_vec[0] * 0.25
                    centerline['y'][idx_lane] = centerline['y'][idx_lane] + cur_vec[1] * 0.25
                    centerline['z'][idx_lane] = centerline['z'][idx_lane] + cur_vec[2] * 0.25
                if start_lane_idx+1 == len(centerline['x']):
                    continue
                cur_vec1 = []
                for idx_lane in range(start, end+1):
                    if idx_lane < start_lane_idx:
                        continue
                    if centerline['lanewidth'][idx_lane] != 1:
                        continue
                    if start_target_p_idx < len(results['gt_bev_lane_freespace']['lane'][vote_idx]['x']):
                        point_target = [results['gt_bev_lane_freespace']['lane'][vote_idx]['x'][start_target_p_idx], results['gt_bev_lane_freespace']['lane'][vote_idx]['y'][start_target_p_idx], results['gt_bev_lane_freespace']['lane'][vote_idx]['z'][start_target_p_idx]]
                        vec_lane_line = [point_target[0] - centerline['x'][idx_lane], point_target[1] - centerline['y'][idx_lane], point_target[2] - centerline['z'][idx_lane]]
                        norm = (vec_lane_line[0]*vec_lane_line[0] + vec_lane_line[1]*vec_lane_line[1] + vec_lane_line[2]*vec_lane_line[2]) ** 0.5
                        cur_vec1 = [vec_lane_line[0] / norm, vec_lane_line[1] / norm, vec_lane_line[2] / norm]
