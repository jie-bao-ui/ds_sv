def load_line_edge_from_gt(json_data, results):
    results['gt_bev_lane_freespace'] = {'lane':[]}
    for line in json_data['annotation']:
        valid = 1
        for ele in line['lineData']:
            if ele['classIndex'] == 5 or ele['classIndex'] == 6 or ele['classIndex'] == 0 or ele['classIndex'] > 15 or (ele['classIndex'] > 6 and ele['classIndex'] < 13):
                valid = 0
                break
        if valid == 1:
            x_s = [ele['x'] for ele in line['lineData']]
            y_s = [ele['y'] for ele in line['lineData']]
            z_s = [ele['z'] for ele in line['lineData']]
            classIndexs = [ele['classIndex'] for ele in line['lineData']]
            new_lane = {}
            new_lane['x'] = x_s
            new_lane['y'] = y_s
            new_lane['z'] = z_s
            new_lane['classIndex'] = classIndexs
            results['gt_bev_lane_freespace']['lane'].append(new_lane)

