def write_lines_to_csv(lines, file_path):
    data_rows = []
    data_rows.append(["wkt", "id"])
    for idx, lane in enumerate(lines):
        str_out = 'LINESTRING('
        for idx_p, x_val in enumerate(lane['x']):
            str_out = str_out + f"{lane['x'][idx_p]}" + " " + f"{lane['y'][idx_p]}"
            if idx_p + 1 < len(lane['x']):
                str_out = str_out + ','
        str_out = str_out + ")"
        data_rows.append([str_out, str(idx)])
    with open(file_path, 'w', newline="", encoding='utf-8') as f:
        writer = csv.writer(f)
        writer.writerows(data_rows)

def load_encrypt_data(json_path, info_type):
        with open(json_path, "rb") as f:
            json_info = f.read()
        key = KEY_DICT[info_type]
        fernet = Fernet(key)
        decrypted_data = fernet.decrypt(json_info)
        json_data = json.loads(decrypted_data.decode("utf-8"))
        return json_data

